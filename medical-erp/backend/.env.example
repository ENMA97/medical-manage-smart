# ══════════════════════════════════════════════
# Medical ERP - Environment Configuration
# ══════════════════════════════════════════════
# Copy this file to .env and configure your values
# For Docker deployment, use docker/.env.production instead

# ── Application ──
APP_NAME="Medical ERP"
APP_ENV=local            # local | staging | production
APP_KEY=                 # Run: php artisan key:generate
APP_DEBUG=true           # MUST be false in production
APP_URL=http://localhost
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ── Logging ──
LOG_CHANNEL=stack
LOG_STACK=single         # single | daily (use 'daily' for production)
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug          # debug | info | warning | error (use 'warning' for production)

# ── Database ──
DB_CONNECTION=sqlite     # sqlite (dev) | pgsql (production)
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=medical_erp
# DB_USERNAME=erp_user
# DB_PASSWORD=

# ── Session ──
SESSION_DRIVER=file      # file (dev) | redis (production)
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Cache / Queue ──
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync    # sync (dev) | redis (production)
CACHE_STORE=file         # file (dev) | redis (production)

# ── Redis ──
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ──
MAIL_MAILER=log          # log (dev) | smtp (production)
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── CORS ──
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Sanctum ──
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
FRONTEND_URL=http://localhost:3000

# ── Optional: Gemini AI ──
# GEMINI_API_KEY=your_api_key_here

# ── Optional: Biometric / ZKTeco ──
# BIOMETRIC_API_TOKEN=
# BIOMETRIC_SYNC_INTERVAL=300

# ── Frontend (Vite) ──
VITE_APP_NAME="${APP_NAME}"
