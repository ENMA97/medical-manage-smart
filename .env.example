# =============================================================================
# Medical ERP Smart - Environment Configuration
# نظام تخطيط الموارد الطبية الذكي
# =============================================================================

# Application Settings
APP_NAME="Medical ERP Smart"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Locale Settings
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_TIMEZONE=Asia/Riyadh

# Database Configuration (PostgreSQL)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=medical_erp
DB_USERNAME=medical_erp
DB_PASSWORD=secret

# Redis Configuration
REDIS_HOST=redis
REDIS_PASSWORD=secret
REDIS_PORT=6379

# Cache & Session
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@medical-erp.local"
MAIL_FROM_NAME="${APP_NAME}"

# JWT Authentication
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160

# Google Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-pro

# SMS Provider (for notifications)
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER_ID=

# Biometric Integration (ZKTeco)
BIOMETRIC_API_TOKEN=
BIOMETRIC_SYNC_INTERVAL=60

# File Storage
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=me-south-1
AWS_BUCKET=

# Docker Ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Frontend
VITE_API_URL=http://localhost:8000/api
VITE_APP_NAME="Medical ERP Smart"

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug
